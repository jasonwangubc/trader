# Copy to .env and fill in. .env is gitignored.

# --- Database ---
# Async (used by the app at runtime)
DATABASE_URL=postgresql+asyncpg://trader:trader@localhost:5433/trader
# Sync (used by Alembic for migrations)
DATABASE_URL_SYNC=postgresql+psycopg2://trader:trader@localhost:5433/trader

# --- App ---
APP_ENV=development
SECRET_KEY=dev-only-change-me-before-prod
PAPER_MODE_DEFAULT=true

# --- Risk defaults (overridable via settings table at runtime) ---
BASE_RISK_PCT=0.0075
MAX_RISK_PCT=0.02

# --- Questrade (filled in during OAuth bootstrap, Sprint 1 step 2) ---
QUESTRADE_LOGIN_SERVER=https://login.questrade.com
QUESTRADE_REFRESH_TOKEN=
QUESTRADE_API_BASE=

# --- Notifications (Sprint 2) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
